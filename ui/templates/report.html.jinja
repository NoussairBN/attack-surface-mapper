{# Jinja template for HTML report #}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Attack Surface Report - {{ manifest.package }}</title>
    <script src="https://cdn.jsdelivr.net/npm/mermaid@10/dist/mermaid.min.js"></script>
    <style>
        body { font-family: Arial, sans-serif; margin: 20px; background: #f5f5f5; }
        .container { max-width: 1200px; margin: 0 auto; background: white; border-radius: 8px; padding: 20px; }
        .header { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 20px; border-radius: 8px; margin-bottom: 20px; }
        .score-card { background: #f0f0f0; padding: 20px; border-radius: 8px; margin: 20px 0; text-align: center; }
        .score-value { font-size: 48px; font-weight: bold; color: #667eea; }
        .risk-level { display: inline-block; padding: 4px 12px; border-radius: 4px; font-weight: bold; }
        .risk-critical { background: #dc3545; color: white; }
        .risk-high { background: #fd7e14; color: white; }
        .risk-medium { background: #ffc107; color: black; }
        .risk-low { background: #28a745; color: white; }
        table { width: 100%; border-collapse: collapse; margin: 20px 0; }
        th, td { padding: 10px; text-align: left; border-bottom: 1px solid #ddd; }
        th { background: #667eea; color: white; }
        .mermaid { background: #fafafa; padding: 20px; border-radius: 8px; overflow-x: auto; }
        .recommendation { background: #e8f5e9; padding: 15px; border-left: 4px solid #4caf50; margin: 10px 0; }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>🔒 Attack Surface Report</h1>
            <p>Package: {{ manifest.package }} | Version: {{ manifest.version }}</p>
            <p>Generated: {{ timestamp }}</p>
        </div>
        
        <div class="score-card">
            <div class="score-value">{{ risk_score }}/100</div>
            <div>Overall Risk Score</div>
            <div class="risk-level risk-{{ risk_level }}">{{ risk_level|upper }} RISK</div>
        </div>
        
        <h2>📊 Statistics</h2>
        <table>
            <tr><th>Metric</th><th>Value</th></tr>
            <tr><td>Total Components</td><td>{{ stats.total_nodes }}</td></tr>
            <tr><td>Exported Components</td><td>{{ stats.exported_count }}</td></tr>
            <tr><td>Critical Risks</td><td>{{ stats.critical_count }}</td></tr>
            <tr><td>High Risks</td><td>{{ stats.high_count }}</td></tr>
        </table>
        
        <h2>🔗 Component Graph</h2>
        <div class="mermaid">
{{ mermaid_code }}
        </div>
        
        <h2>📋 Component Details</h2>
        <table>
            <tr>
                <th>Component</th>
                <th>Type</th>
                <th>Exported</th>
                <th>Permission</th>
                <th>Risk</th>
            </tr>
            {% for component in components %}
            <tr>
                <td>{{ component.name }}</td>
                <td>{{ component.type }}</td>
                <td>{{ "Yes" if component.exported else "No" }}</td>
                <td>{{ component.permission or "None" }}</td>
                <td class="risk-{{ component.risk }}">{{ component.risk|upper }}</td>
            </tr>
            {% endfor %}
        </table>
        
        <h2>💡 Recommendations</h2>
        {% for rec in recommendations %}
        <div class="recommendation">
            {{ rec }}
        </div>
        {% endfor %}
    </div>
    <script>
        mermaid.initialize({ startOnLoad: true, theme: 'default' });
    </script>
</body>
</html>